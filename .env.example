# Calendar Planner — environment variables
# Copy this file to `.env` (which is gitignored) and fill in real values.

# Google OAuth (see docs/google-setup.md for how to obtain these).
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are filled in by hand after creating
# the OAuth client in Google Cloud Console. GOOGLE_REFRESH_TOKEN is filled in by
# the `npm run auth` script (slice 003).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# Gemini API key (https://aistudio.google.com/apikey).
# Used by the Plan Parser (slice 005).
GEMINI_API_KEY=

# Server ports.
API_PORT=3001
WEB_PORT=5173

# Log level for the API (trace | debug | info | warn | error | fatal).
LOG_LEVEL=info

# SQLite database file (relative to apps/api/prisma/).
DATABASE_URL=file:./dev.db
