{
  "name": "@calendar-planner/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth": "tsx src/auth/runAuth.ts"
  },
  "dependencies": {
    "@calendar-planner/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.1.0",
    "fastify-plugin": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
